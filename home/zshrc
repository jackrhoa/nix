export JAVA_HOME=$(/usr/libexec/java_home -v 21)

export PATH=$(brew --prefix openssh)/bin:$PATH

alias claude-sr='CLAUDE_CONFIG_DIR=~/.claude-sports-reference claude'

alias claude-personal='CLAUDE_CONFIG_DIR=$HOME/.claude claude'

# alias ls='ls --color=auto'

zmodload zsh/datetime

export AWS_VAULT_PROMPT=ykman
export YKMAN_OATH_CREDENTIAL_NAME="${YKMAN_OATH_CREDENTIAL_NAME:-sr-aws}"

awslogin() {
  emulate -L zsh
  local profile="${1:-$AWS_PROFILE}"
  if [[ -z "$profile" ]]; then
    print -u2 "usage: awslogin <profile>"
    return 1
  fi

  unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN AWS_CREDENTIAL_EXPIRATION

  local creds
  creds=$(aws-vault export --format=env "$profile") || return 1

  local line
  while IFS= read -r line; do
    [[ "$line" == *=* ]] || continue
    export "${line%%=*}=${line#*=}"
  done <<< "$creds"

  export AWS_PROFILE="$profile"
  if [[ -n "$AWS_CREDENTIAL_EXPIRATION" ]]; then
    print -P "%F{green}done%f $profile, expires $AWS_CREDENTIAL_EXPIRATION"
  else
    print -P "%F{green}done%f $profile (no expiry)"
  fi
}

typeset -g _AWS_EXP_SRC=""
typeset -g _AWS_EXP_EPOCH=""

_aws_profile_prompt() {
  [[ -z "$AWS_PROFILE" ]] && return
  if [[ "$AWS_CREDENTIAL_EXPIRATION" != "$_AWS_EXP_SRC" ]]; then
    _AWS_EXP_SRC="$AWS_CREDENTIAL_EXPIRATION"
    _AWS_EXP_EPOCH=""
    if [[ -n "$AWS_CREDENTIAL_EXPIRATION" ]]; then
      local clean="${AWS_CREDENTIAL_EXPIRATION%%[+Z]*}"
      clean="${clean%.*}"
      _AWS_EXP_EPOCH=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%S" "$clean" "+%s" 2>/dev/null)
    fi
  fi
  if [[ -z "$_AWS_EXP_EPOCH" ]]; then
    print -rn "%F{blue}[aws:${AWS_PROFILE}]%f "
    return
  fi
  local left=$(( _AWS_EXP_EPOCH - EPOCHSECONDS ))
  if (( left <= 0 )); then
    print -rn "%F{blue}[aws:${AWS_PROFILE} %F{red}expired%f%F{blue}]%f "
    return
  fi
  local color
  if (( left < 900 )); then color="yellow"; else color="green"; fi
  print -rn "%F{blue}[aws:${AWS_PROFILE} %F{$color}$((left/60))m%f%F{blue}]%f "
}

